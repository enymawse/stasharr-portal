generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id        String        @id @default(cuid())
  stashId   String        @unique
  status    RequestStatus @default(REQUESTED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model SceneIndex {
  stashId                String                 @id
  requestStatus          RequestStatus?
  requestUpdatedAt       DateTime?
  title                  String?
  description            String?
  imageUrl               String?
  studioId               String?
  studioName             String?
  studioImageUrl         String?
  releaseDate            String?
  duration               Int?
  whisparrMovieId        Int?
  whisparrHasFile        Boolean?
  whisparrQueuePosition  Int?
  whisparrQueueStatus    String?
  whisparrQueueState     String?
  whisparrErrorMessage   String?
  stashAvailable         Boolean?
  computedLifecycle      SceneLifecycle         @default(NOT_REQUESTED)
  lifecycleSortOrder     Int                    @default(999)
  metadataHydrationState MetadataHydrationState @default(PENDING)
  metadataLastSyncedAt   DateTime?
  metadataRetryAfterAt   DateTime?
  whisparrLastSyncedAt   DateTime?
  stashLastSyncedAt      DateTime?
  lastSyncedAt           DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  @@index([computedLifecycle, lifecycleSortOrder, whisparrQueuePosition, requestUpdatedAt])
  @@index([requestUpdatedAt])
  @@index([whisparrMovieId])
  @@index([metadataLastSyncedAt])
  @@index([whisparrLastSyncedAt])
  @@index([stashLastSyncedAt])
  @@index([lastSyncedAt])
}

model SyncState {
  jobName            String        @id
  status             SyncJobStatus @default(IDLE)
  startedAt          DateTime?
  finishedAt         DateTime?
  leaseUntil         DateTime?
  cursor             String?
  lastError          String?
  lastSuccessAt      DateTime?
  lastDurationMs     Int?
  lastProcessedCount Int?
  lastUpdatedCount   Int?
  lastRunReason      String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model SceneIndexSummary {
  key                      String    @id
  indexedScenes            Int       @default(0)
  acquisitionTrackedScenes Int       @default(0)
  requestedCount           Int       @default(0)
  downloadingCount         Int       @default(0)
  importPendingCount       Int       @default(0)
  failedCount              Int       @default(0)
  metadataPendingCount     Int       @default(0)
  metadataRetryableCount   Int       @default(0)
  lastIndexWriteAt         DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
}

model LibrarySceneIndex {
  stashSceneId         String    @id
  linkedStashId        String?
  linkedCatalogRefs    String[]  @default([])
  title                String
  description          String?
  imageUrl             String?
  studioId             String?
  studioName           String?
  studioImageUrl       String?
  performerIds         String[]  @default([])
  performerNames       String[]  @default([])
  tagIds               String[]  @default([])
  tagNames             String[]  @default([])
  releaseDate          String?
  duration             Int?
  viewUrl              String
  localCreatedAt       DateTime?
  localUpdatedAt       DateTime?
  hasFavoritePerformer Boolean   @default(false)
  favoriteStudio       Boolean   @default(false)
  hasFavoriteTag       Boolean   @default(false)
  lastSyncedAt         DateTime
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([linkedStashId])
  @@index([studioId])
  @@index([studioName])
  @@index([title])
  @@index([tagIds], type: Gin, map: "LibrarySceneIndex_tagIds_gin_idx")
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin, map: "LibrarySceneIndex_title_trgm_idx")
  @@index([description(ops: raw("gin_trgm_ops"))], type: Gin, map: "LibrarySceneIndex_description_trgm_idx")
  @@index([studioName(ops: raw("gin_trgm_ops"))], type: Gin, map: "LibrarySceneIndex_studioName_trgm_idx")
  @@index([releaseDate])
  @@index([localCreatedAt])
  @@index([localUpdatedAt])
  @@index([lastSyncedAt])
}

model HomeRail {
  id          String              @id @default(cuid())
  key         HomeRailKey?        @unique
  kind        HomeRailKind
  source      HomeRailSource
  contentType HomeRailContentType
  title       String
  subtitle    String?
  enabled     Boolean             @default(true)
  sortOrder   Int
  config      Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([sortOrder])
}

enum RequestStatus {
  REQUESTED
  PROCESSING
  AVAILABLE
  FAILED
}

enum SceneLifecycle {
  NOT_REQUESTED
  REQUESTED
  DOWNLOADING
  IMPORT_PENDING
  AVAILABLE
  FAILED
}

enum SyncJobStatus {
  IDLE
  RUNNING
  SUCCEEDED
  FAILED
}

enum MetadataHydrationState {
  PENDING
  HYDRATED
  FAILED_RETRYABLE
}

enum HomeRailKey {
  FAVORITE_STUDIOS
  FAVORITE_PERFORMERS
  RECENTLY_ADDED_LIBRARY
}

enum HomeRailKind {
  BUILTIN
  CUSTOM
}

enum HomeRailSource {
  STASHDB
  STASH
  HYBRID
}

enum HomeRailContentType {
  SCENES
}

enum IntegrationType {
  STASHDB
  STASH
  WHISPARR
}

enum IntegrationStatus {
  NOT_CONFIGURED
  CONFIGURED
  ERROR
}

model IntegrationConfig {
  id      String            @id @default(cuid())
  type    IntegrationType   @unique
  enabled Boolean           @default(true)
  status  IntegrationStatus @default(NOT_CONFIGURED)

  name    String?
  baseUrl String?
  apiKey  String?

  config Json?

  lastHealthyAt    DateTime?
  lastErrorAt      DateTime?
  lastErrorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
