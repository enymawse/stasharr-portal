generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Request {
  id        String        @id @default(cuid())
  stashId   String        @unique
  status    RequestStatus @default(REQUESTED)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model HomeRail {
  id          String              @id @default(cuid())
  key         HomeRailKey?        @unique
  kind        HomeRailKind
  source      HomeRailSource
  contentType HomeRailContentType
  title       String
  subtitle    String?
  enabled     Boolean             @default(true)
  sortOrder   Int
  config      Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([sortOrder])
}

enum RequestStatus {
  REQUESTED
  PROCESSING
  AVAILABLE
  FAILED
}

enum HomeRailKey {
  FAVORITE_STUDIOS
  FAVORITE_PERFORMERS
  RECENTLY_ADDED_LIBRARY
}

enum HomeRailKind {
  BUILTIN
  CUSTOM
}

enum HomeRailSource {
  STASHDB
  STASH
  HYBRID
}

enum HomeRailContentType {
  SCENES
}

enum IntegrationType {
  STASHDB
  STASH
  WHISPARR
}

enum IntegrationStatus {
  NOT_CONFIGURED
  CONFIGURED
  ERROR
}

model IntegrationConfig {
  id               String            @id @default(cuid())
  type             IntegrationType   @unique
  enabled          Boolean           @default(true)
  status           IntegrationStatus @default(NOT_CONFIGURED)

  name             String?
  baseUrl          String?
  apiKey           String?

  config           Json?

  lastHealthyAt    DateTime?
  lastErrorAt      DateTime?
  lastErrorMessage String?

  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}
