# Secondary repo-checkout deployment path. The primary self-hosted install flow is the
# standalone compose example in README.md or infrastructure/compose/compose.example.yaml.
# Stable channel for most self-hosted installs. Use an exact vX.Y.Z tag to pin a release,
# or edge to track unreleased builds from main.
STASHARR_IMAGE_TAG=latest
DATABASE_HOST=postgres
HOST=0.0.0.0
PORT=3000
DATABASE_MIGRATION_MAX_ATTEMPTS=30
DATABASE_MIGRATION_RETRY_DELAY_SECONDS=2
# Optional advanced override. Leave unset to let Stasharr generate and persist
# a unique session secret for this install in the app data volume.
# SESSION_SECRET=change-this-session-secret
# Optional: set to true when Stasharr is served over HTTPS and you want a Secure session cookie.
# SESSION_COOKIE_SECURE=false
