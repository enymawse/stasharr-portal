{
  "name": "stasharr-portal",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "format": "pnpm -r format",
    "web": "pnpm --filter ./apps/sp-web start",
    "backend": "pnpm --filter ./apps/sp-api start:dev",
    "dev:db": "docker compose -f infrastructure/compose/docker-compose.yml up -d postgres",
    "db:repair-runtime-health-migration": "node scripts/repair-runtime-health-migration.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "pg": "^8.20.0",
    "prisma": "^7.4.2"
  }
}
